    "files.encoding": "utf8bom",
    "clang-format.executable": "clang-format", // 确保在 PATH 中
    "clang-format.style": "file", // 使用项目中的 .clang-format 文件
    "[cpp]": {
        "editor.defaultFormatter": "xaver.clang-format"
    },
    "[c]": {
        "editor.defaultFormatter": "xaver.clang-format"
    },
    "C_Cpp.errorSquiggles": "disabled",
    "editor.formatOnSave": false,
    "terminal.integrated.profiles.windows": {
        "PowerShell": {
            "source": "PowerShell",
            "icon": "terminal-powershell",
        },
        "Command Prompt": {
            "path": [
                "${env:windir}\\Sysnative\\cmd.exe",
                "${env:windir}\\System32\\cmd.exe"
            ],
            "args": [],
            "icon": "terminal-cmd"
        },
        "Git Bash": {
            "source": "Git Bash",
            "icon": "terminal-git-bash"
        }
    },
    "terminal.integrated.defaultProfile.windows": "Git Bash",
    "cmake.outputLogEncoding": "gbk",
    "cmake.useCMakePresets": "always",
    // 防止 CMake Tools 干扰 clangd；切换 preset 后仍应 Configure 一次
    "cmake.configureOnOpen": false,
    "cmake.buildBeforeRun": false,
    "cmake.enableAutomaticKitScan": false,
    "cmake.enableKitScan": false,
  // 切换 configure preset 时自动重新 configure，并刷新 compile_commands.json 副本
    "cmake.automaticReconfigure": true,
    "cmake.exportCompileCommandsFile": true,
    "cmake.loadCompileCommands": true,
    // 将「当前 active preset」构建目录中的 compile_commands.json 复制到仓库根目录
    // （与各 preset 的 binaryDir 对应，如 out/build/osgengine-ninja-cl、out/build/osgengine-ninja-clangcl）
    "cmake.copyCompileCommands": "${workspaceFolder}/compile_commands.json",

    // --- clangd：始终读取仓库根目录的 compile_commands.json（由 copyCompileCommands 同步）---
    "clangd.path": "C:/Program Files/LLVM/bin/clangd.exe",
    "clangd.arguments": [
        "--compile-commands-dir=${workspaceFolder}",
        "--query-driver=**/cl.exe,**/clang-cl.exe",
        "--header-insertion=never",
        "--completion-style=detailed"
    ],

    // 关闭微软 C++ IntelliSense，避免与 clangd 重复诊断
    "C_Cpp.intelliSenseEngine": "disabled",
    "C_Cpp.workspaceParsingPriority": "low",
    "C_Cpp.autocomplete": "disabled"
}